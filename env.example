# ── Required ──────────────────────────────────────────
TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxYZ
TELEGRAM_CHANNEL=@your_channel_username

# ── Recommended ───────────────────────────────────────
NVD_API_KEY=your-nvd-api-key-here
GITHUB_TOKEN=ghp_your_github_token_here   # raises GitHub API rate limit

# ── Optional tuning ───────────────────────────────────
MIN_SEVERITY=5.0          # 5.0 to 10.0
POLL_INTERVAL=300         # seconds between checks (300 = 5 min)
